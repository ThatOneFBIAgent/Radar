        "text": "#E0E0E0",
        "text_dim": "#666680",
        "text_bright": "#FFFFFF",
        "success": "#00FF88",
        "warning": "#FFD700",
        "danger": "#FF3366",
        "border": "#2A2A4A",
        "border_focus": "#00D4FF",
        "scrollbar": "#333355",
        "scrollbar_active": "#00D4FF",
        "header": "#0F0F1E",
        "row_even": "#12122A",
        "row_odd": "#16163A",
        "highlight": "#FF6B3522",
